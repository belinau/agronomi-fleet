def _kiss_escape(data):
    """Escape bytes for KISS framing: 0xDB → 0xDB 0xDD, 0xC0 → 0xDB 0xDC."""
    out = bytearray()
    for b in data:
        if b == 0xDB:
            out.extend(b"\xdb\xdd")
        elif b == 0xC0:
            out.extend(b"\xdb\xdc")
        else:
            out.append(b)
    return bytes(out)


def _kiss_unescape(data):
    """Unescape KISS bytes: 0xDB 0xDD → 0xDB, 0xDB 0xDC → 0xC0."""
    out = bytearray()
    i = 0
    while i < len(data):
        if data[i] == 0xDB and i + 1 < len(data):
            if data[i + 1] == 0xDD:
                out.append(0xDB)
                i += 2
                continue
            elif data[i + 1] == 0xDC:
                out.append(0xC0)
                i += 2
                continue
        out.append(data[i])
        i += 1
    return bytes(out)


