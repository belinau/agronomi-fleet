# 99-pico.rules — udev rule for Raspberry Pi Pico 2W
#
# Creates a /dev/pico symlink when the Pico is plugged in, and
# sets permissions so the 'livada' user can access it without sudo.
# On Pico 2W with MicroPython, the USB CDC ACM device appears as
# /dev/ttyACM0 (or ttyACM1, etc). This rule creates a stable symlink
# so ble_forwarder can always find it at /dev/pico.
#
# Install on Mimi:
#   sudo cp 99-pico.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#   Then unplug/replug the Pico.
#
# Verify:
#   ls -la /dev/pico
#   Should point to /dev/ttyACM0 or similar
#   id livada  # should show dialout group
#   sudo usermod -aG dialout livada  # if not in group

# Raspberry Pi Pico 2W (MicroPython USB CDC runtime — "Board in FS mode")
SUBSYSTEM=="tty", ATTRS{idVendor}=="2e8a", ATTRS{idProduct}=="0005", SYMLINK+="pico", MODE="0666"

# Raspberry Pi Pico 2W (UF2 bootloader mode)
SUBSYSTEM=="tty", ATTRS{idVendor}=="2e8a", ATTRS{idProduct}=="000c", SYMLINK+="pico-boot", MODE="0666"

# Original Raspberry Pi Pico (MicroPython USB CDC)
SUBSYSTEM=="tty", ATTRS{idVendor}=="2e8a", ATTRS{idProduct}=="000a", SYMLINK+="pico", MODE="0666"
